# youJob environment configuration
# Copy this file to `.env.local` for local development.
# Add the same server-side values to Vercel Project Settings -> Environment Variables.

# ============================================
# DATABASE
# ============================================

# Primary PostgreSQL connection used by Prisma.
# Supabase example:
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@your-project.supabase.co:5432/postgres?schema=public"

# Local example:
# DATABASE_URL="postgresql://username:password@localhost:5432/youjob?schema=public"

# ============================================
# SUPABASE AUTH / CLIENT
# ============================================

# Required if you are using Supabase auth/client code in the app.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
NEXT_PUBLIC_SUPABASE_RESUME_BUCKET="resumes"
SUPABASE_RESUME_BUCKET="resumes"

# ============================================
# APP URLS
# ============================================

# Local app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Production example on Vercel:
# NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# ============================================
# INTERNAL API SECURITY
# ============================================

# Used by the GitHub Action / internal import route.
# Generate with: openssl rand -base64 32
JOB_IMPORT_API_KEY="your-super-secret-key-here"

# ============================================
# TINYFISH OPEN-WEB DISCOVERY
# ============================================

# TinyFish key used for job discovery via Search + Fetch.
TINYFISH_API_KEY="your-tinyfish-api-key"

# Discovery queries used by `npm run fetch:jobs`.
# Keep these targeted. Broad queries will produce noisy results.
JOB_DISCOVERY_QUERIES="remote react engineer startup careers,site:company.com careers software engineer"

# Optional TinyFish search shaping
JOB_SEARCH_LOCATION="US"
JOB_SEARCH_LANGUAGE="en"
JOB_SEARCH_RESULTS_PER_QUERY="5"
JOB_MAX_CANDIDATE_PAGES="30"

# Optional fallback/extra structured source shaped like:
# { "jobs": [ ... ] }
CUSTOM_JOB_SOURCE_URL="https://api.example.com/jobs"
CUSTOM_JOB_SOURCE_API_KEY="source-api-key"

# ============================================
# AI / RANKING
# ============================================

# Gemini key used through `@ai-sdk/google`.
GEMINI_API_KEY="your-gemini-api-key"

# Optional future model defaults
# AI_RANKING_MODEL="gemini-2.5-flash"

# ============================================
# CV / PROFILE PARSING
# ============================================

# Add any extra provider-specific keys here when you wire resume parsing.

# ============================================
# DEVELOPMENT
# ============================================

NODE_ENV="development"
DEBUG="prisma:*"

# ============================================
# VERCEL DEPLOYMENT NOTES
# ============================================

# Add these to Vercel for production:
# - DATABASE_URL
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - NEXT_PUBLIC_APP_URL
# - JOB_IMPORT_API_KEY
# - TINYFISH_API_KEY
# - JOB_DISCOVERY_QUERIES
# - JOB_SEARCH_LOCATION
# - JOB_SEARCH_LANGUAGE
# - JOB_SEARCH_RESULTS_PER_QUERY
# - JOB_MAX_CANDIDATE_PAGES
# - GEMINI_API_KEY
